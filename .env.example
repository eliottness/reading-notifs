# App
APP_URL=http://localhost:3000
NODE_ENV=development

# Database
DATABASE_URL=local.db

# Auth
BETTER_AUTH_SECRET=change-me-in-production

# Admin: comma-separated emails granted access to the /admin/* endpoints (e.g. the synchronous
# refresh endpoint). Matching is case-insensitive. Leave empty to disable admin access entirely.
ADMIN_EMAILS=

# Access control: restrict who may sign in / sign up. ALLOWED_DOMAINS is a comma-separated list of
# email domains (e.g. example.com), ALLOWED_EMAILS a comma-separated list of individual addresses.
# An email is allowed if its domain OR the address itself matches. Matching is case-insensitive.
# Leave BOTH empty to allow anyone (the default). Enabling the allowlist does not remove or lock out
# pre-existing users — it only stops disallowed addresses from obtaining new sessions.
ALLOWED_DOMAINS=
ALLOWED_EMAILS=

# Email (SMTP)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@reading-notifs.local

# Web Push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@reading-notifs.local
